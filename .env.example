# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-key

# Server
PORT=10000
ALLOWED_ORIGINS=https://patrikfriis-alt.github.io,http://localhost:3000

# Config (optional, defaults provided)
CLAUDE_MODEL=claude-haiku-4-5-20251001
CLAUDE_MAX_TOKENS=2048
PDF_MIN_SIZE=1000
PDF_REQUEST_DELAY_MS=1500
NEWS_SYNC_INTERVAL_MS=86400000
FEED_SYNC_INTERVAL_MS=3600000
HTTP_TIMEOUT_MS=30000
REQUEST_RETRY_ATTEMPTS=3
REQUEST_RETRY_DELAY_MS=1000
PARALLEL_REQUESTS=5
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

# Debug (optional)
# DEBUG=true
